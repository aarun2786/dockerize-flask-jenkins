pipeline{
    agent any
    stages{
        stage("clone code"){
            steps{
                git 'https://github.com/aarun2786/jenkins_dockerize_flask.git'
            }
        }
        stage("build docker image"){
            steps{
                sh 'docker build -t flask-app:lastest .'
            }
        }
        stage("run docker container"){
            steps{
                sh 'docker run -d -p 5000:5000 flask-app:lastest'
            }
        }
    }
}
